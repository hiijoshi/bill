NODE_ENV=development

# Local development database (SQLite)
DATABASE_URL="file:./dev.db"

# Production database (Turso / libSQL)
# TURSO_DATABASE_URL="libsql://your-database.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"
# USE_TURSO="true"

# Required application secrets
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
REFRESH_SECRET="replace-with-a-different-long-random-secret-at-least-32-chars"

# Allowed frontend origins, comma-separated
ALLOWED_ORIGINS="http://localhost:3000"

# Optional infrastructure
# REDIS_URL="redis://localhost:6379"
# SUPER_ADMIN_REMOTE_ACCESS="false"
# SUPER_ADMIN_SECOND_SECRET=""

# Optional CAPTCHA
# CAPTCHA_ENABLED="false"
# CAPTCHA_PROVIDER=""
# CAPTCHA_SITE_KEY=""
# CAPTCHA_SECRET_KEY=""

# Optional Supabase auth bridge. Only set these if you intentionally enable it.
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
