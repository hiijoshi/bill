{
  "name": "billing-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-safe.mjs",
    "dev:turbo": "NEXT_DEV_ENGINE=turbopack node scripts/dev-safe.mjs",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:stable": "next dev --webpack",
    "prebuild": "prisma generate",
    "build": "node scripts/build.mjs",
    "build:analyze": "ANALYZE=true npm run build",
    "postinstall": "prisma generate",
    "start": "next start",
    "start:prod": "PORT=${PORT:-3000} next start",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "lint": "eslint",
    "prisma:dbpush": "prisma db push",
    "prisma:migrate:deploy": "node scripts/prisma-migrate-deploy.mjs",
    "prisma:migrate:baseline": "node scripts/prisma-migrate-baseline.mjs",
    "test:security": "tsx --test tests/security-upgrade.test.ts",
    "turso:setup-test-data": "tsx scripts/setup-turso-test-data.ts",
    "bootstrap:super-admin": "tsx scripts/bootstrap-super-admin.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.8.0",
    "@prisma/adapter-libsql": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "next": "^16.2.1",
    "pdf-parse": "^2.4.5",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "redis": "^5.11.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.4.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "webpack-bundle-analyzer": "^5.3.0"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "brace-expansion": "^5.0.5"
    },
    "brace-expansion@^1.1.7": "^1.1.13",
    "flatted@^3.2.9": "^3.4.2",
    "picomatch": "^4.0.4"
  }
}
