// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ... the rest of your models remain the same

model Trader {
  id                   String                @id @default(cuid())
  name                 String
  maxCompanies         Int?
  maxUsers             Int?
  locked               Boolean               @default(false)
  deletedAt            DateTime?
  // relations
  users                User[]
  companies            Company[]
  subscriptions        TraderSubscription[]
  subscriptionPayments SubscriptionPayment[]
  dataLifecycle        TraderDataLifecycle?
  dataBackups          TraderDataBackup[]
  financialYears       FinancialYear[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([deletedAt], map: "idx_traders_deleted_at")
}

model FinancialYear {
  id          String   @id @default(cuid())
  traderId    String
  trader      Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)
  label       String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  status      String   @default("open")
  activatedAt DateTime?
  closedAt    DateTime?
  lockedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([traderId, label], map: "uniq_financial_years_trader_label")
  @@unique([traderId, startDate, endDate], map: "uniq_financial_years_trader_window")
  @@index([traderId, isActive, status], map: "idx_financial_years_trader_active_status")
  @@index([traderId, startDate, endDate], map: "idx_financial_years_trader_window")
  @@index([traderId, createdAt], map: "idx_financial_years_trader_created")
}

model SubscriptionPlan {
  id               String                    @id @default(cuid())
  name             String
  description      String?
  billingCycle     String                    @default("yearly")
  amount           Float                     @default(0)
  currency         String                    @default("INR")
  maxCompanies     Int?
  maxUsers         Int?
  defaultTrialDays Int?
  isActive         Boolean                   @default(true)
  isTrialCapable   Boolean                   @default(false)
  sortOrder        Int                       @default(0)
  features         SubscriptionPlanFeature[]
  subscriptions    TraderSubscription[]
  payments         SubscriptionPayment[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([isActive, sortOrder], map: "idx_subscription_plans_active_sort")
  @@index([billingCycle], map: "idx_subscription_plans_billing_cycle")
}

model SubscriptionPlanFeature {
  id           String           @id @default(cuid())
  planId       String
  plan         SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey   String
  featureLabel String
  description  String?
  enabled      Boolean          @default(true)
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([planId, featureKey], map: "uniq_subscription_plan_feature")
  @@index([featureKey, enabled], map: "idx_subscription_plan_features_key_enabled")
}

model TraderSubscription {
  id                   String                      @id @default(cuid())
  traderId             String
  trader               Trader                      @relation(fields: [traderId], references: [id], onDelete: Cascade)
  planId               String?
  plan                 SubscriptionPlan?           @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscriptionType     String
  status               String
  billingCycle         String?
  amount               Float                       @default(0)
  currency             String                      @default("INR")
  planNameSnapshot     String?
  startDate            DateTime
  endDate              DateTime
  activatedAt          DateTime?
  expiredAt            DateTime?
  cancelledAt          DateTime?
  suspendedAt          DateTime?
  trialDays            Int?
  maxCompaniesOverride Int?
  maxUsersOverride     Int?
  notes                String?
  assignedByUserId     String?
  updatedByUserId      String?
  features             TraderSubscriptionFeature[]
  payments             SubscriptionPayment[]
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([traderId, status], map: "idx_trader_subscriptions_trader_status")
  @@index([traderId, startDate, endDate], map: "idx_trader_subscriptions_date_window")
  @@index([planId], map: "idx_trader_subscriptions_plan_id")
}

model TraderSubscriptionFeature {
  id             String             @id @default(cuid())
  subscriptionId String
  subscription   TraderSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  featureKey     String
  featureLabel   String
  description    String?
  enabled        Boolean            @default(true)
  sortOrder      Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([subscriptionId, featureKey], map: "uniq_trader_subscription_feature")
  @@index([featureKey, enabled], map: "idx_trader_subscription_features_key_enabled")
}

model SubscriptionPayment {
  id                   String              @id @default(cuid())
  traderId             String
  trader               Trader              @relation(fields: [traderId], references: [id], onDelete: Cascade)
  traderSubscriptionId String?
  traderSubscription   TraderSubscription? @relation(fields: [traderSubscriptionId], references: [id], onDelete: SetNull)
  planId               String?
  plan                 SubscriptionPlan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  amount               Float
  currency             String              @default("INR")
  status               String              @default("confirmed")
  paymentMode          String              @default("manual")
  referenceNo          String?
  paidAt               DateTime?
  confirmedAt          DateTime?
  confirmedByUserId    String?
  planNameSnapshot     String?
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([traderId, createdAt], map: "idx_subscription_payments_trader_created_at")
  @@index([traderSubscriptionId], map: "idx_subscription_payments_subscription_id")
  @@index([status, paymentMode], map: "idx_subscription_payments_status_mode")
}

model TraderDataLifecycle {
  id                       String    @id @default(cuid())
  traderId                 String    @unique
  trader                   Trader    @relation(fields: [traderId], references: [id], onDelete: Cascade)
  state                    String    @default("active")
  readOnlySince            DateTime?
  backupRequestedAt        DateTime?
  backupRequestedByUserId  String?
  latestReadyBackupId      String?
  latestReadyBackupAt      DateTime?
  closureRequestedAt       DateTime?
  closureRequestedByUserId String?
  closureRequestSource     String?
  closureNotes             String?
  retentionDays            Int?
  scheduledDeletionAt      DateTime?
  deletionPendingAt        DateTime?
  deletionMarkedByUserId   String?
  deletionApprovedAt       DateTime?
  deletionApprovedByUserId String?
  deletionExecutedAt       DateTime?
  deletionExecutedByUserId String?
  notes                    String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([state, scheduledDeletionAt], map: "idx_trader_data_lifecycle_state_schedule")
  @@index([latestReadyBackupAt], map: "idx_trader_data_lifecycle_latest_backup_at")
}

model TraderDataBackup {
  id                String    @id @default(cuid())
  traderId          String
  trader            Trader    @relation(fields: [traderId], references: [id], onDelete: Cascade)
  requestedByUserId String?
  requestedByRole   String?
  requestSource     String    @default("super_admin")
  status            String    @default("pending")
  format            String    @default("json")
  fileName          String?
  storagePath       String?
  fileSizeBytes     Int?
  checksum          String?
  recordCountsJson  String?
  exportedAt        DateTime?
  lastDownloadedAt  DateTime?
  downloadCount     Int       @default(0)
  failedAt          DateTime?
  errorMessage      String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([traderId, status, createdAt], map: "idx_trader_data_backups_trader_status_created")
  @@index([exportedAt], map: "idx_trader_data_backups_exported_at")
}

model User {
  id          String           @id @default(cuid())
  traderId    String
  trader      Trader           @relation(fields: [traderId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId      String
  password    String
  name        String?
  role        String? // super_admin/trader_admin/company_admin/company_user
  locked      Boolean          @default(false)
  deletedAt   DateTime?
  // relations
  permissions UserPermission[]
  uploadedBankStatementBatches BankStatementBatch[] @relation("BankStatementBatchUploadedBy")
  reviewedBankStatementRows    BankStatementRow[]   @relation("BankStatementRowReviewedBy")
  createdBankReconciliationLinks BankReconciliationLink[] @relation("BankReconciliationLinkCreatedBy")
  bankStatementBatchEvents     BankStatementBatchEvent[] @relation("BankStatementBatchEventActor")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([traderId, userId])
  @@index([companyId], map: "idx_users_company_id")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@index([traderId, deletedAt], map: "idx_users_trader_deleted")
  @@index([traderId, companyId, deletedAt], map: "idx_users_trader_company_deleted")
}

model Company {
  id                   String                @id @default(cuid())
  traderId             String?
  trader               Trader?               @relation(fields: [traderId], references: [id], onDelete: SetNull)
  name                 String
  address              String?
  phone                String?
  mandiAccountNumber   String?
  // relations
  parties              Party[]
  farmers              Farmer[]
  suppliers            Supplier[]
  products             Product[]
  users                User[]
  units                Unit[]
  salesItemMasters     SalesItemMaster[]
  purchaseBills        PurchaseBill[]
  salesBills           SalesBill[]
  salesBillSplitGroups SalesBillSplitGroup[]
  specialPurchaseBills SpecialPurchaseBill[]
  stockLedger          StockLedger[]
  payments             Payment[]
  transports           Transport[]
  banks                Bank[]
  accountingHeads      AccountingHead[]
  mandiTypes           MandiType[]
  billCharges          BillCharge[]
  ledgerEntries        LedgerEntry[]
  markas               Marka[]
  paymentModes         PaymentMode[]
  salesAdditionalCharges SalesAdditionalCharge[]
  userPermissions      UserPermission[]
  bankStatementBatches BankStatementBatch[]
  bankStatementRows    BankStatementRow[]
  bankReconciliationLinks BankReconciliationLink[]
  bankStatementBatchEvents BankStatementBatchEvent[]
  locked               Boolean               @default(false)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([traderId], map: "idx_companies_trader_id")
  @@index([name], map: "idx_companies_name")
  @@index([deletedAt], map: "idx_companies_deleted_at")
  @@index([traderId, deletedAt, createdAt], map: "idx_companies_trader_deleted_created")
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module    String
  canRead   Boolean  @default(false)
  canWrite  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId, module], map: "uniq_user_company_module_permission")
  @@index([companyId, module], map: "idx_permissions_company_module")
  @@index([userId], map: "idx_permissions_user_id")
  @@index([userId, companyId], map: "idx_permissions_user_company")
}

model Party {
  id                 String             @id @default(cuid())
  companyId          String
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type               String // farmer/buyer
  name               String
  address            String?
  phone1             String?
  phone2             String?
  openingBalance     Float              @default(0)
  openingBalanceType String             @default("receivable")
  openingBalanceDate DateTime?
  creditLimit        Float?
  creditDays         Int?
  ifscCode           String?
  bankName           String?
  accountNo          String?
  // relations
  salesBills         SalesBill[]
  payments           Payment[]
  mandiProfile       PartyMandiProfile?
  ledgerEntries      LedgerEntry[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([companyId, name], map: "idx_parties_company_name")
  @@index([companyId, openingBalance], map: "idx_parties_company_opening_balance")
}

model Farmer {
  id                    String              @id @default(cuid())
  companyId             String
  company               Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                  String
  address               String?
  phone1                String?
  phone2                String?
  ifscCode              String?
  bankName              String?
  accountNo             String?
  krashakAnubandhNumber String? // Farmer registration number
  // relations
  purchaseBills         PurchaseBill[]
  payments              Payment[]
  mandiProfile          FarmerMandiProfile?
  ledgerEntries         LedgerEntry[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([companyId, name], map: "idx_farmers_company_name")
}

model Supplier {
  id                   String                @id @default(cuid())
  companyId            String
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                 String
  address              String?
  phone1               String?
  phone2               String?
  ifscCode             String?
  bankName             String?
  accountNo            String?
  gstNumber            String?
  // relations
  specialPurchaseBills SpecialPurchaseBill[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([companyId, name], map: "idx_suppliers_company_name")
}

model Unit {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  symbol       String
  kgEquivalent Float     @default(1)
  isUniversal  Boolean   @default(false)
  description  String?
  // relations
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([companyId, symbol])
}

model Product {
  id                   String                @id @default(cuid())
  companyId            String
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                 String
  unitId               String
  unit                 Unit                  @relation(fields: [unitId], references: [id])
  hsnCode              String?
  gstRate              Float?
  sellingPrice         Float?
  description          String?
  isActive             Boolean               @default(true)
  // relations
  purchaseItems        PurchaseItem[]
  salesItems           SalesItem[]
  salesItemMasters     SalesItemMaster[]
  specialPurchaseItems SpecialPurchaseItem[]
  stockLedger          StockLedger[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([companyId, name])
}

model PurchaseBill {
  id                         String         @id @default(cuid())
  companyId                  String
  company                    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billNo                     String
  billDate                   DateTime
  farmerId                   String
  farmer                     Farmer         @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerNameSnapshot         String?
  farmerAddressSnapshot      String?
  farmerContactSnapshot      String?
  krashakAnubandhSnapshot    String?
  companyNameSnapshot        String?
  mandiAccountNumberSnapshot String?
  subTotalAmount             Float          @default(0)
  gstAmount                  Float          @default(0)
  totalAmount                Float
  paidAmount                 Float          @default(0)
  balanceAmount              Float          @default(0)
  status                     String // unpaid/partial/paid
  createdBy                  String?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  // relations
  purchaseItems              PurchaseItem[]

  @@index([companyId, billDate], map: "idx_purchase_bills_company_date")
  @@index([companyId, status, billDate, createdAt], map: "idx_purchase_bills_company_status_date_created")
}

model PurchaseItem {
  id                  String       @id @default(cuid())
  purchaseBillId      String
  purchaseBill        PurchaseBill @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)
  productId           String
  product             Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productNameSnapshot String?
  qty                 Float
  rate                Float
  hammali             Float?
  bags                Int?
  markaNo             String?
  taxableAmount       Float        @default(0)
  gstRateSnapshot     Float?
  gstAmount           Float        @default(0)
  lineTotal           Float        @default(0)
  amount              Float
  userUnitName        String?
  kgEquivalent        Float?
  totalWeightQt       Float?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([purchaseBillId], map: "idx_purchase_items_bill_id")
}

model SpecialPurchaseBill {
  id                   String                @id @default(cuid())
  companyId            String
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierInvoiceNo    String
  billDate             DateTime
  supplierId           String
  supplier             Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  subTotalAmount       Float                 @default(0)
  gstAmount            Float                 @default(0)
  totalAmount          Float
  paidAmount           Float                 @default(0)
  balanceAmount        Float                 @default(0)
  status               String // unpaid/partial/paid
  createdBy            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  // relations
  specialPurchaseItems SpecialPurchaseItem[]

  @@index([companyId, billDate], map: "idx_special_purchase_bills_company_date")
  @@index([companyId, status, billDate, createdAt], map: "idx_special_purchase_bills_company_status_date_created")
}

model SpecialPurchaseItem {
  id                    String              @id @default(cuid())
  specialPurchaseBillId String
  specialPurchaseBill   SpecialPurchaseBill @relation(fields: [specialPurchaseBillId], references: [id], onDelete: Cascade)
  productId             String
  product               Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  noOfBags              Int?
  weight                Float
  rate                  Float
  taxableAmount         Float               @default(0)
  gstRateSnapshot       Float?
  gstAmount             Float               @default(0)
  netAmount             Float
  otherAmount           Float?
  grossAmount           Float
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model SalesBill {
  id                  String                @id @default(cuid())
  companyId           String
  company             Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billNo              String
  billDate            DateTime
  partyId             String
  party               Party                 @relation(fields: [partyId], references: [id], onDelete: Cascade)
  subTotalAmount      Float                 @default(0)
  gstAmount           Float                 @default(0)
  totalAmount         Float
  receivedAmount      Float                 @default(0)
  balanceAmount       Float                 @default(0)
  status              String // unpaid/partial/paid
  invoiceKind         String                @default("regular")
  workflowStatus      String                @default("posted")
  parentSalesBillId   String?
  parentSalesBill     SalesBill?            @relation("SalesBillParentChild", fields: [parentSalesBillId], references: [id], onDelete: SetNull)
  childSalesBills     SalesBill[]           @relation("SalesBillParentChild")
  splitGroupId        String?
  splitGroup          SalesBillSplitGroup?  @relation("SalesBillSplitGroupBills", fields: [splitGroupId], references: [id], onDelete: SetNull)
  splitAsParentGroup  SalesBillSplitGroup?  @relation("SalesBillSplitGroupParent")
  splitSuffix         String?
  splitSequence       Int?
  splitMethod         String?
  splitReason         String?
  splitPartLabel      String?
  lockedAt            DateTime?
  splitFinalizedAt    DateTime?
  createdBy           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  // relations
  salesItems          SalesItem[]
  transportBills      TransportBill[]
  additionalCharges   SalesAdditionalCharge[]
  splitAllocations    SalesBillSplitAllocation[] @relation("SalesSplitAllocationChildBill")

  @@index([companyId, billDate], map: "idx_sales_bills_company_date")
  @@index([companyId, status, billDate, createdAt], map: "idx_sales_bills_company_status_date_created")
  @@index([companyId, partyId, billDate], map: "idx_sales_bills_company_party_date")
  @@unique([parentSalesBillId, splitSuffix], map: "uniq_sales_bills_parent_suffix")
  @@index([companyId, invoiceKind, workflowStatus, billDate, createdAt], map: "idx_sales_bills_company_kind_workflow_date_created")
  @@index([parentSalesBillId, splitSequence], map: "idx_sales_bills_parent_sequence")
  @@index([splitGroupId], map: "idx_sales_bills_split_group")
}

model SalesItem {
  id                     String                     @id @default(cuid())
  salesBillId            String
  salesBill              SalesBill                  @relation(fields: [salesBillId], references: [id], onDelete: Cascade)
  productId              String
  product                Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  weight                 Float
  bags                   Int?
  rate                   Float
  taxableAmount          Float                      @default(0)
  gstRateSnapshot        Float?
  gstAmount              Float                      @default(0)
  lineTotal              Float                      @default(0)
  amount                 Float
  parentSplitAllocations SalesBillSplitAllocation[] @relation("SalesSplitAllocationParentItem")
  childSplitAllocations  SalesBillSplitAllocation[] @relation("SalesSplitAllocationChildItem")
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  @@index([salesBillId], map: "idx_sales_items_bill_id")
}

model SalesBillSplitGroup {
  id                  String                     @id @default(cuid())
  companyId           String
  company             Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentSalesBillId   String                     @unique
  parentSalesBill     SalesBill                  @relation("SalesBillSplitGroupParent", fields: [parentSalesBillId], references: [id], onDelete: Cascade)
  status              String                     @default("draft")
  splitMethod         String
  chargeAllocationMode String                    @default("proportional_amount")
  reason              String?
  notes               String?
  sourceBillSnapshot  String?
  validationSnapshot  String?
  createdBy           String?
  updatedBy           String?
  finalizedAt         DateTime?
  mergedAt            DateTime?
  lockedAt            DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  childBills          SalesBill[]                @relation("SalesBillSplitGroupBills")
  allocations         SalesBillSplitAllocation[]

  @@index([companyId, status, createdAt], map: "idx_sales_split_groups_company_status_created")
  @@index([companyId, splitMethod], map: "idx_sales_split_groups_company_method")
}

model SalesBillSplitAllocation {
  id              String              @id @default(cuid())
  splitGroupId    String
  splitGroup      SalesBillSplitGroup @relation(fields: [splitGroupId], references: [id], onDelete: Cascade)
  parentSalesItemId String
  parentSalesItem SalesItem           @relation("SalesSplitAllocationParentItem", fields: [parentSalesItemId], references: [id], onDelete: Cascade)
  childSalesBillId String
  childSalesBill  SalesBill           @relation("SalesSplitAllocationChildBill", fields: [childSalesBillId], references: [id], onDelete: Cascade)
  childSalesItemId String?
  childSalesItem  SalesItem?          @relation("SalesSplitAllocationChildItem", fields: [childSalesItemId], references: [id], onDelete: SetNull)
  allocationMode  String?
  sourceIndex     Int                 @default(0)
  weight          Float               @default(0)
  bags            Int?
  rate            Float               @default(0)
  amount          Float               @default(0)
  taxableAmount   Float               @default(0)
  gstAmount       Float               @default(0)
  lineTotal       Float               @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([splitGroupId, parentSalesItemId, childSalesBillId, sourceIndex], map: "uniq_sales_split_allocations_group_item_bill_index")
  @@index([splitGroupId, childSalesBillId], map: "idx_sales_split_allocations_group_child_bill")
  @@index([parentSalesItemId], map: "idx_sales_split_allocations_parent_item")
  @@index([childSalesItemId], map: "idx_sales_split_allocations_child_item")
}

model SalesItemMaster {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesItemName String // Custom name for sales item display
  hsnCode       String?
  gstRate       Float?
  sellingPrice  Float?
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, productId], map: "idx_sales_item_master_company_product")
}

model StockLedger {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entryDate DateTime
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String // purchase/sales/adjustment
  qtyIn     Float    @default(0)
  qtyOut    Float    @default(0)
  refTable  String // purchase_bills/sales_bills/stock_adjustments
  refId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, entryDate], map: "idx_stock_ledger_company_date")
  @@index([companyId, productId, entryDate], map: "idx_stock_ledger_company_product_date")
  @@index([productId, entryDate], map: "idx_stock_ledger_product_date")
  @@index([companyId, type, entryDate], map: "idx_stock_ledger_company_type_date")
}

model Payment {
