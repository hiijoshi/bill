// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ... the rest of your models remain the same

model Trader {
  id        String   @id @default(cuid())
  name      String
  maxCompanies Int?
  maxUsers  Int?
  locked    Boolean  @default(false)
  deletedAt DateTime?
  // relations
  users     User[]
  companies Company[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt], map: "idx_traders_deleted_at")
}

model User {
  id        String   @id @default(cuid())
  traderId  String
  trader    Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId    String
  password  String
  name      String?
  role      String?  // super_admin/trader_admin/company_admin/company_user
  locked    Boolean  @default(false)
  deletedAt DateTime?
  // relations
  permissions UserPermission[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([traderId, userId])
  @@index([companyId], map: "idx_users_company_id")
  @@index([deletedAt], map: "idx_users_deleted_at")
}

model Company {
  id            String   @id @default(cuid())
  traderId      String?  
  trader        Trader?  @relation(fields: [traderId], references: [id], onDelete: SetNull)
  name          String
  address       String?
  phone         String?
  mandiAccountNumber String?
  // relations
  parties       Party[]
  farmers       Farmer[]
  suppliers     Supplier[]
  products      Product[]
  users         User[]
  units         Unit[]
  salesItemMasters SalesItemMaster[]
  purchaseBills PurchaseBill[]
  salesBills    SalesBill[]
  specialPurchaseBills SpecialPurchaseBill[]
  stockLedger   StockLedger[]
  payments      Payment[]
  transports    Transport[]
  banks         Bank[]
  accountingHeads AccountingHead[]
  mandiTypes    MandiType[]
  billCharges   BillCharge[]
  ledgerEntries LedgerEntry[]
  markas        Marka[]
  paymentModes  PaymentMode[]
  userPermissions UserPermission[]
  locked        Boolean  @default(false)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([traderId], map: "idx_companies_trader_id")
  @@index([name], map: "idx_companies_name")
  @@index([deletedAt], map: "idx_companies_deleted_at")
}

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  module    String
  canRead   Boolean  @default(false)
  canWrite  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId, module], map: "uniq_user_company_module_permission")
  @@index([companyId, module], map: "idx_permissions_company_module")
  @@index([userId], map: "idx_permissions_user_id")
}

model Party {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      String   // farmer/buyer
  name      String
  address   String?
  phone1    String?
  phone2    String?
  openingBalance Float  @default(0)
  openingBalanceType String @default("receivable")
  openingBalanceDate DateTime?
  creditLimit Float?
  creditDays Int?
  ifscCode  String?
  bankName  String?
  accountNo String?
  // relations
  salesBills SalesBill[]
  payments Payment[]
  mandiProfile PartyMandiProfile?
  ledgerEntries LedgerEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Farmer {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  phone1    String?
  phone2    String?
  ifscCode  String?
  bankName  String?
  accountNo String?
  krashakAnubandhNumber String? // Farmer registration number
  // relations
  purchaseBills PurchaseBill[]
  payments Payment[]
  mandiProfile FarmerMandiProfile?
  ledgerEntries LedgerEntry[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  phone1    String?
  phone2    String?
  ifscCode  String?
  bankName  String?
  accountNo String?
  gstNumber String?
  // relations
  specialPurchaseBills SpecialPurchaseBill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  symbol      String
  kgEquivalent Float   @default(1)
  isUniversal Boolean  @default(false)
  description String?
  // relations
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, symbol])
}

model Product {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  unitId        String
  unit          Unit     @relation(fields: [unitId], references: [id])
  hsnCode       String?
  gstRate       Float?
  sellingPrice  Float?
  description   String?
  isActive      Boolean  @default(true)
  // relations
  purchaseItems PurchaseItem[]
  salesItems    SalesItem[]
  salesItemMasters SalesItemMaster[]
  specialPurchaseItems SpecialPurchaseItem[]
  stockLedger   StockLedger[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, name])
}

model PurchaseBill {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billNo        String
  billDate      DateTime
  farmerId      String
  farmer        Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  farmerNameSnapshot String?
  farmerAddressSnapshot String?
  farmerContactSnapshot String?
  krashakAnubandhSnapshot String?
  companyNameSnapshot String?
  mandiAccountNumberSnapshot String?
  subTotalAmount Float   @default(0)
  gstAmount     Float    @default(0)
  totalAmount   Float
  paidAmount    Float    @default(0)
  balanceAmount Float    @default(0)
  status        String   // unpaid/partial/paid
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // relations
  purchaseItems PurchaseItem[]

  @@index([companyId, billDate], map: "idx_purchase_bills_company_date")
}

model PurchaseItem {
  id             String   @id @default(cuid())
  purchaseBillId String
  purchaseBill   PurchaseBill @relation(fields: [purchaseBillId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productNameSnapshot String?
  qty            Float
  rate           Float
  hammali        Float?
  bags           Int?
  markaNo        String?
  taxableAmount  Float    @default(0)
  gstRateSnapshot Float?
  gstAmount      Float    @default(0)
  lineTotal      Float    @default(0)
  amount         Float
  userUnitName   String?
  kgEquivalent   Float?
  totalWeightQt  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SpecialPurchaseBill {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierInvoiceNo   String
  billDate            DateTime
  supplierId          String
  supplier            Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  subTotalAmount       Float    @default(0)
  gstAmount            Float    @default(0)
  totalAmount         Float
  paidAmount          Float    @default(0)
  balanceAmount       Float    @default(0)
  status              String   // unpaid/partial/paid
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  // relations
  specialPurchaseItems SpecialPurchaseItem[]
}

model SpecialPurchaseItem {
  id                    String   @id @default(cuid())
  specialPurchaseBillId String
  specialPurchaseBill   SpecialPurchaseBill @relation(fields: [specialPurchaseBillId], references: [id], onDelete: Cascade)
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  noOfBags              Int?
  weight                Float
  rate                  Float
  taxableAmount         Float    @default(0)
  gstRateSnapshot       Float?
  gstAmount             Float    @default(0)
  netAmount             Float
  otherAmount           Float?
  grossAmount           Float
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SalesBill {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billNo        String
  billDate      DateTime
  partyId       String
  party         Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  subTotalAmount Float   @default(0)
  gstAmount     Float    @default(0)
  totalAmount   Float
  receivedAmount Float   @default(0)
  balanceAmount Float    @default(0)
  status        String   // unpaid/partial/paid
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // relations
  salesItems    SalesItem[]
  transportBills TransportBill[]

  @@index([companyId, billDate], map: "idx_sales_bills_company_date")
}

model SalesItem {
  id          String   @id @default(cuid())
  salesBillId String
  salesBill   SalesBill @relation(fields: [salesBillId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  weight      Float
  bags        Int?
  rate        Float
  taxableAmount Float   @default(0)
  gstRateSnapshot Float?
  gstAmount   Float     @default(0)
  lineTotal   Float     @default(0)
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SalesItemMaster {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesItemName String   // Custom name for sales item display
  hsnCode       String?
  gstRate       Float?
  sellingPrice  Float?
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, productId], map: "idx_sales_item_master_company_product")
}

model StockLedger {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entryDate  DateTime
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       String   // purchase/sales/adjustment
  qtyIn      Float    @default(0)
  qtyOut     Float    @default(0)
  refTable   String   // purchase_bills/sales_bills/stock_adjustments
  refId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId, entryDate], map: "idx_stock_ledger_company_date")
  @@index([companyId, productId, entryDate], map: "idx_stock_ledger_company_product_date")
  @@index([productId, entryDate], map: "idx_stock_ledger_product_date")
}

model Payment {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partyId    String?
  party      Party?   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  farmerId   String?
  farmer     Farmer?  @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  billType   String   // purchase/sales
  billId     String
  billDate    DateTime
  payDate     DateTime
  amount      Float
  mode        String   // cash/online/bank
  cashAmount  Float?
  cashPaymentDate DateTime?
  onlinePayAmount Float?
  onlinePaymentDate DateTime?
  ifscCode    String?
  beneficiaryBankAccount String?
  bankNameSnapshot String?
  bankBranchSnapshot String?
  asFlag      String?  @default("A")
  status      String   @default("pending")
  txnRef      String?
  note        String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([billType, billId], map: "idx_payments_bill_type")
  @@index([companyId, payDate], map: "idx_payments_company_date")
  @@index([deletedAt], map: "idx_payments_deleted_at")
}

model AuditLog {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  actorId        String
  actorRole      String
  actorIp        String?
  actorUserAgent String?
  action         String
  resourceType   String
  resourceId     String
  scope          String?
  before         String?
  after          String?
  diff           String?
  requestId      String?
  notes          String?

  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([actorId], map: "idx_audit_logs_actor_id")
  @@index([resourceType, resourceId], map: "idx_audit_logs_resource")
}

model Transport {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transporterName String
  vehicleNumber   String?
  driverName      String?
  driverPhone     String?
  vehicleType     String?
  description     String?
  capacity        Float?
  freightRate     Float?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Bank {
  id            String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  branch        String?
  ifscCode      String
  accountNumber String?
  address       String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, name, ifscCode])
  @@index([companyId, name], map: "idx_banks_company_name")
}

model AccountingHead {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  category    String
  amount      Float    @default(0)
  value       Float    @default(0)
  mandiConfig AccountingHeadMandiConfig?
  billCharges BillCharge[]
  ledgerEntries LedgerEntry[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, category], map: "idx_accounting_heads_company_category")
  @@index([companyId, name], map: "idx_accounting_heads_company_name")
}

model MandiType {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partyProfiles PartyMandiProfile[]
  farmerProfiles FarmerMandiProfile[]
  accountingHeadConfigs AccountingHeadMandiConfig[]
  billCharges BillCharge[]

  @@unique([companyId, name], map: "uniq_mandi_types_company_name")
  @@index([companyId, isActive], map: "idx_mandi_types_company_active")
}

model PartyMandiProfile {
  id          String   @id @default(cuid())
  partyId     String   @unique
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  mandiTypeId String?
  mandiType   MandiType? @relation(fields: [mandiTypeId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mandiTypeId], map: "idx_party_mandi_profiles_mandi_type")
}

model FarmerMandiProfile {
  id          String   @id @default(cuid())
  farmerId    String   @unique
  farmer      Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  mandiTypeId String?
  mandiType   MandiType? @relation(fields: [mandiTypeId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mandiTypeId], map: "idx_farmer_mandi_profiles_mandi_type")
}

model AccountingHeadMandiConfig {
  id               String   @id @default(cuid())
  accountingHeadId String   @unique
  accountingHead   AccountingHead @relation(fields: [accountingHeadId], references: [id], onDelete: Cascade)
  mandiTypeId      String?
  mandiType        MandiType? @relation(fields: [mandiTypeId], references: [id], onDelete: SetNull)
  isMandiCharge    Boolean  @default(false)
  calculationBasis String?
  defaultValue     Float    @default(0)
  accountGroup     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([mandiTypeId, isMandiCharge], map: "idx_accounting_head_mandi_config_type_charge")
}

model Marka {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  markaNumber String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, markaNumber])
  @@index([companyId, markaNumber], map: "idx_markas_company_number")
}

model PaymentMode {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  code        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId, name], map: "idx_payment_modes_company_name")
}

model BillCharge {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billType         String
  billId           String
  accountingHeadId String?
  accountingHead   AccountingHead? @relation(fields: [accountingHeadId], references: [id], onDelete: SetNull)
  mandiTypeId      String?
  mandiType        MandiType? @relation(fields: [mandiTypeId], references: [id], onDelete: SetNull)
  nameSnapshot     String
  categorySnapshot String?
  calculationBasis String?
  basisValue       Float    @default(0)
  chargeAmount     Float    @default(0)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId, billType, billId], map: "idx_bill_charges_company_bill")
  @@index([accountingHeadId], map: "idx_bill_charges_head")
}

model LedgerEntry {
  id                    String   @id @default(cuid())
  companyId             String
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entryDate             DateTime
  billType              String
  billId                String
  direction             String
  amount                Float
  partyId               String?
  party                 Party?   @relation(fields: [partyId], references: [id], onDelete: SetNull)
  farmerId              String?
  farmer                Farmer?  @relation(fields: [farmerId], references: [id], onDelete: SetNull)
  accountingHeadId      String?
  accountingHead        AccountingHead? @relation(fields: [accountingHeadId], references: [id], onDelete: SetNull)
  accountHeadNameSnapshot String?
  accountGroupSnapshot  String?
  counterpartyNameSnapshot String?
  note                  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId, entryDate], map: "idx_ledger_entries_company_date")
  @@index([billType, billId], map: "idx_ledger_entries_bill")
  @@index([partyId], map: "idx_ledger_entries_party")
  @@index([farmerId], map: "idx_ledger_entries_farmer")
  @@index([accountingHeadId], map: "idx_ledger_entries_head")
}

model TransportBill {
  id            String   @id @default(cuid())
  salesBillId   String
  salesBill     SalesBill @relation(fields: [salesBillId], references: [id], onDelete: Cascade)
  transportName String?
  lorryNo      String?
  freightPerQt  Float?
  freightAmount Float?
  advance       Float?    @default(0)
  toPay         Float?    @default(0)
  otherAmount   Float?    @default(0)
  insuranceAmount Float?  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
